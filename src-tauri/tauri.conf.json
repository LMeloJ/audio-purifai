{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Enhancer",
  "version": "0.3.0",
  "identifier": "com.audioenhancer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Audio Enhancer",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "deb", "appimage"],
    "resources": {
      "../scripts": "scripts"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "template": "installer.nsi"
      }
    }
  }
}
